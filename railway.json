{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python tg_super_agent.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "variables": {
    "SESSION_STRING": {
      "description": "Строка сессии Telegram (получи через get_session.py)",
      "required": true
    },
    "API_ID": {
      "description": "API ID из my.telegram.org (число)",
      "required": true
    },
    "API_HASH": {
      "description": "API Hash из my.telegram.org (строка)",
      "required": true
    },
    "XAI_API_KEY": {
      "description": "Ключ от Grok API (xai-...)",
      "required": true
    }
  }
}
